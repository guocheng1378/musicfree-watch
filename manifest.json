{
  "package": "com.musicfree.watch",
  "name": "MusicFree手表版",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minAPILevel": 1,
  "deviceTypeList": ["watch"],
  "config": {
    "logLevel": "log",
    "designWidth": 480,
    "background": {
      "features": ["system.audio", "system.request"]
    }
  },
  "features": [
    { "name": "system.audio" },
    { "name": "system.request" },
    { "name": "system.storage" }
  ],
  "permissions": [],
  "router": {
    "entry": "Index",
    "pages": {
      "Index": {
        "component": "index",
        "path": "/Index"
      },
      "Search": {
        "component": "search",
        "path": "/Search"
      },
      "Player": {
        "component": "player",
        "path": "/Player"
      }
    }
  },
  "display": {
    "backgroundColor": "#000000"
  }
}
