{
  "package": "com.musicfree.watch",
  "name": "MusicFree手表版",
  "versionName": "1.1.0",
  "versionCode": 2,
  "minAPILevel": 1,
  "icon": "/common/icon.png",
  "deviceTypeList": ["watch"],
  "config": {
    "logLevel": "log",
    "designWidth": "device-width",
    "background": {
      "features": ["system.audio"]
    }
  },
  "features": [
    { "name": "system.router" },
    { "name": "system.fetch" },
    { "name": "system.request" },
    { "name": "system.audio" },
    { "name": "system.storage" }
  ],
  "permissions": [],
  "router": {
    "entry": "pages/Index",
    "pages": {
      "pages/Index": {
        "component": "index",
        "path": "/Index"
      },
      "pages/Player": {
        "component": "player",
        "path": "/Player"
      }
    }
  },
  "display": {
    "backgroundColor": "#000000"
  }
}
